#!/usr/bin/env -S uv run python
"""
DESCRIPTION: Lint a plan file against plan_standards.md (structure, numbering, iconography).
Usage: uv run python ai_bin/plans validate <plan-file>
  <plan-file>  Filename only — just the filename, not the path (e.g. plan_0210_foo.md).
"""
from __future__ import annotations

import os as _os

if _os.environ.get("AIBIN_DISPATCHER") != "1":
    print("ERROR: This script must be run via its dispatcher (e.g. uv run python ai_bin/nb ...). "
          "Direct invocation is not permitted.", file=__import__('sys').stderr)
    __import__('sys').exit(1)
import re
import sys
from pathlib import Path

PROJECT_ROOT = Path(__file__).resolve().parent.parent.parent
PLANS_DIR = PROJECT_ROOT / "plans"

REQUIRED_SECTIONS = ["## Objective", "## Logic & Rationale", "## Phases", "## Verification Checklist"]
PHASE_RE = re.compile(r"^#{2,4}\s+Phase\s+(\d+)", re.IGNORECASE)
NUMBERED_ITEM_RE = re.compile(r"^(\d+)\.\s+")
ICON_SET = {"🧪", "🏗️", "⚙️", "📊", "🏁", "✔️", "🔄"}


def main() -> None:
    if "--help" in sys.argv or "-h" in sys.argv or "help" in sys.argv or len(sys.argv) < 2:
        print(__doc__)
        sys.exit(0)

    plan_arg = sys.argv[1]
    path = Path(plan_arg)
    if not path.is_absolute():
        path = PLANS_DIR / plan_arg

    if not path.exists():
        print(f"ERROR: {path} not found.", file=sys.stderr)
        sys.exit(1)

    text = path.read_text(encoding="utf-8")
    lines = text.splitlines()
    errors: list[str] = []

    # 1. Required sections
    for section in REQUIRED_SECTIONS:
        if not any(line.startswith(section) for line in lines):
            errors.append(f"Missing required section: '{section}'")

    # 2. H1 title present
    if not any(line.startswith("# ") for line in lines):
        errors.append("Missing H1 title (# Plan: ...)")

    # 3. Phase numbering starts at 1 and is sequential
    phase_numbers: list[int] = []
    for line in lines:
        m = PHASE_RE.match(line)
        if m:
            phase_numbers.append(int(m.group(1)))
    if phase_numbers:
        if phase_numbers[0] != 1:
            errors.append(f"Phase numbering must start at 1, found Phase {phase_numbers[0]}")
        for i in range(1, len(phase_numbers)):
            if phase_numbers[i] != phase_numbers[i - 1] + 1:
                errors.append(
                    f"Non-sequential phase numbering: Phase {phase_numbers[i - 1]} → Phase {phase_numbers[i]}"
                )

    # 4. Numbered list items start at 1 and are sequential within a block
    prev_num: int | None = None
    for lineno, line in enumerate(lines, start=1):
        m = NUMBERED_ITEM_RE.match(line)
        if m:
            n = int(m.group(1))
            if prev_num is None:
                if n != 1:
                    errors.append(f"Line {lineno}: Numbered list starts at {n}, expected 1")
            else:
                if n != prev_num + 1 and n != 1:
                    errors.append(f"Line {lineno}: Non-sequential numbering ({prev_num} → {n})")
            prev_num = n
        else:
            if line.strip():
                prev_num = None

    # 5. At least one iconography symbol used
    if not any(icon in text for icon in ICON_SET):
        errors.append("No iconography symbols found (🧪 🏗️ ⚙️ 📊 🏁 ✔️ 🔄)")

    # 6. Verification checklist has at least one item
    in_checklist = False
    checklist_items = 0
    for line in lines:
        if line.startswith("## Verification Checklist"):
            in_checklist = True
            continue
        if in_checklist:
            if line.startswith("## "):
                break
            if re.match(r"^\s*-\s*\[", line):
                checklist_items += 1
    if checklist_items == 0:
        errors.append("Verification Checklist has no items")

    if errors:
        print(f"FAIL: {len(errors)} issue(s) found in {path.name}")
        for e in errors:
            print(f"  ✗ {e}")
        sys.exit(1)
    else:
        print(f"OK: {path.name} passes all checks.")


if __name__ == "__main__":
    main()
