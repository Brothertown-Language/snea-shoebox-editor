#!/usr/bin/env -S uv run python
"""
DESCRIPTION: List all active plans with title and progress % (checked vs unchecked steps).
Usage: uv run python ai_bin/plans list
"""
from __future__ import annotations

import os as _os

if _os.environ.get("AIBIN_DISPATCHER") != "1":
    print("ERROR: This script must be run via its dispatcher (e.g. uv run python ai_bin/nb ...). "
          "Direct invocation is not permitted.", file=__import__('sys').stderr)
    __import__('sys').exit(1)
import re
import sys
from pathlib import Path

PROJECT_ROOT = Path(__file__).resolve().parent.parent.parent
PLANS_DIR = PROJECT_ROOT / "plans"
EXCLUDE_NAMES = {"plan_standards.md"}


def plan_progress(text: str) -> tuple[int, int]:
    checked = len(re.findall(r"-\s\[x\]", text, re.IGNORECASE))
    unchecked = len(re.findall(r"-\s\[ \]", text))
    return checked, checked + unchecked


def plan_title(text: str, filename: str) -> str:
    for line in text.splitlines():
        if line.startswith("# "):
            return line[2:].strip()
    return filename


def main() -> None:
    if "--help" in sys.argv or "-h" in sys.argv:
        print(__doc__)
        sys.exit(0)

    plans = sorted(
        p for p in PLANS_DIR.glob("*.md")
        if p.name not in EXCLUDE_NAMES
    )

    if not plans:
        print("No active plans found.")
        return

    for plan in plans:
        text = plan.read_text(encoding="utf-8")
        title = plan_title(text, plan.name)
        checked, total = plan_progress(text)
        pct = f"{int(checked / total * 100)}%" if total else "n/a"
        print(f"{plan.name}  |  {title}  |  {checked}/{total} steps ({pct})")


if __name__ == "__main__":
    main()
