#!/usr/bin/env -S uv run python
"""
DESCRIPTION: Move a completed plan to plans/archive/YYYY-MM/ (current year-month by default).
Usage: uv run python ai_bin/plans archive <plan-file> [YYYY-MM]
  <plan-file>  Filename only — just the filename, not the path (e.g. plan_0210_foo.md).
  [YYYY-MM]    Optional archive subfolder. Defaults to current year-month.
"""
from __future__ import annotations

import os as _os

if _os.environ.get("AIBIN_DISPATCHER") != "1":
    print("ERROR: This script must be run via its dispatcher (e.g. uv run python ai_bin/nb ...). "
          "Direct invocation is not permitted.", file=__import__('sys').stderr)
    __import__('sys').exit(1)
import shutil
import sys
from datetime import datetime, timezone
from pathlib import Path

PROJECT_ROOT = Path(__file__).resolve().parent.parent.parent
PLANS_DIR = PROJECT_ROOT / "plans"


def main() -> None:
    if "--help" in sys.argv or "-h" in sys.argv or "help" in sys.argv or len(sys.argv) < 2:
        print(__doc__)
        sys.exit(0)

    plan_arg = sys.argv[1]
    year_month = sys.argv[2] if len(sys.argv) >= 3 else datetime.now(tz=timezone.utc).strftime("%Y-%m")

    path = Path(plan_arg)
    if not path.is_absolute():
        path = PLANS_DIR / plan_arg

    if not path.exists():
        print(f"ERROR: {path} not found.", file=sys.stderr)
        sys.exit(1)

    archive_dir = PLANS_DIR / "archive" / year_month
    archive_dir.mkdir(parents=True, exist_ok=True)

    dest = archive_dir / path.name
    if dest.exists():
        print(f"ERROR: {dest} already exists in archive.", file=sys.stderr)
        sys.exit(1)

    shutil.move(str(path), str(dest))
    print(f"Archived: plans/archive/{year_month}/{path.name}")


if __name__ == "__main__":
    main()
