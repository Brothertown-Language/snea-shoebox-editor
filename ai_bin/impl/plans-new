#!/usr/bin/env -S uv run python
"""
DESCRIPTION: Scaffold a new plan .md file in plans/ using the mandatory structure from plan_standards.md.
Usage: uv run python ai_bin/plans new <slug> <"Objective sentence">
  <slug>       Short identifier, e.g. 0300_my_feature  (plan_ prefix added automatically)
  <objective>  Single-sentence objective (quoted)
"""
from __future__ import annotations

import os as _os

if _os.environ.get("AIBIN_DISPATCHER") != "1":
    print("ERROR: This script must be run via its dispatcher (e.g. uv run python ai_bin/nb ...). "
          "Direct invocation is not permitted.", file=__import__('sys').stderr)
    __import__('sys').exit(1)
import sys
from pathlib import Path

PROJECT_ROOT = Path(__file__).resolve().parent.parent.parent
PLANS_DIR = PROJECT_ROOT / "plans"

TEMPLATE = """\
# Plan: {title}

## Objective
{objective}

## Logic & Rationale

<!-- Explain WHY this change is needed before describing HOW. -->

## Phases

### Phase 1 ⚙️

1. 🔄 Step one
2. 🔄 Step two

## Verification Checklist

- [ ] Scope compliance verified
- [ ] Fail-fast checks included
- [ ] KISS/DRY applied
- [ ] Plan progress updated and archived on completion

## Progress

🔄 Pending
"""


def main() -> None:
    if "--help" in sys.argv or "-h" in sys.argv or len(sys.argv) < 3:
        print(__doc__)
        sys.exit(0)

    slug = sys.argv[1]
    objective = sys.argv[2]

    if not slug.startswith("plan_"):
        slug = f"plan_{slug}"
    if not slug.endswith(".md"):
        slug = f"{slug}.md"

    dest = PLANS_DIR / slug
    if dest.exists():
        print(f"ERROR: {dest} already exists.", file=sys.stderr)
        sys.exit(1)

    title = slug.removesuffix(".md").removeprefix("plan_").replace("_", " ").title()
    dest.write_text(TEMPLATE.format(title=title, objective=objective), encoding="utf-8")
    print(f"Created: plans/{slug}")


if __name__ == "__main__":
    main()
