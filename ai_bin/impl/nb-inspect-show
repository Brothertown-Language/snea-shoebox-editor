#!/usr/bin/env -S uv run python
"""
DESCRIPTION: Read and display notebook cell contents (code/markdown) with cell index, type, label (if set), and line numbers. This is a read-only analysis tool — it does NOT execute any code.

Usage: uv run python ai_bin/nb inspect show <notebook.ipynb> [--cell <index> | --label <value>] [--json] [--help]

All cell indices are 1-based (first cell = 1).
Primary:  Jupyter Server REST API on port 18888 (GET /api/contents/<path>).
Fallback: nbformat.read(..., as_version=4) when server is not reachable.
NOTE: Cell labels are strongly recommended. Without them, check-labels and other tools may report
      "No labelled cells were found in the notebook". Add labels via cell metadata: {"label": "my-label"}.
"""
from __future__ import annotations

import os as _os

if _os.environ.get("AIBIN_DISPATCHER") != "1":
    print("ERROR: This script must be run via its dispatcher (e.g. uv run python ai_bin/nb ...). "
          "Direct invocation is not permitted.", file=__import__('sys').stderr)
    __import__('sys').exit(1)

import json
import subprocess
import sys
import time
from pathlib import Path

import requests
import nbformat

BASE_DIR = Path(__file__).resolve().parent.parent.parent  # project root
PORT = 18888
BASE_URL = f"http://localhost:{PORT}"


def _is_port_listening() -> bool:
    result = subprocess.run(["ss", "-tlnp"], capture_output=True, text=True)
    return f":{PORT}" in result.stdout


def _ensure_server() -> bool:
    if _is_port_listening():
        return True
    result = subprocess.run(
        ["uv", "run", "jupyter", "server", "--version"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        return False
    log = BASE_DIR / "tmp" / "jupyter.log"
    log.parent.mkdir(parents=True, exist_ok=True)
    subprocess.Popen(
        ["uv", "run", "jupyter", "server", "--no-browser",
         f"--port={PORT}", "--IdentityProvider.token=",
         "--ServerApp.disable_check_xsrf=True"],
        stdout=open(log, "a"), stderr=subprocess.STDOUT, cwd=str(BASE_DIR),
    )
    for _ in range(16):
        time.sleep(0.5)
        if _is_port_listening():
            return True
    return False


def _fetch_via_api(rel_path: str) -> list[dict] | None:
    try:
        r = requests.get(f"{BASE_URL}/api/contents/{rel_path}?type=notebook", timeout=3)
        r.raise_for_status()
        cells = r.json()["content"]["cells"]
        return cells
    except SystemExit:
        raise
    except requests.exceptions.RequestException:
        return None


def _fetch_via_nbformat(path: Path) -> list[dict]:
    with path.open(encoding="utf-8") as f:
        nb = nbformat.read(f, as_version=4)
    return nb.cells


def _resolve_label(cells: list, label: str) -> int:
    """Return the 0-based index of the cell whose metadata['label'] == label.

    Exits 1 if the label is not found.
    Exits 1 if the label matches more than one cell (duplicate — notebook is corrupt).
    Error messages report 1-based indices so the agent can act on them directly.
    """

    def _meta(cell):
        return cell.get("metadata", {}) if isinstance(cell, dict) else dict(cell.get("metadata", {}))

    # Report 1-based indices in error messages for consistency
    matches = [i for i, cell in enumerate(cells) if _meta(cell).get("label") == label]
    if len(matches) == 0:
        print(f"Error: no cell with metadata.label={label!r}.", file=sys.stderr)
        sys.exit(1)
    if len(matches) > 1:
        print(
            f"Error: duplicate label {label!r} found at cell indices {[i + 1 for i in matches]} (1-based). "
            "Fix the notebook before using --label.",
            file=sys.stderr,
        )
        sys.exit(1)
    return matches[0]  # 0-based, converted to 1-based at display time


def _build_records(cells: list) -> list[dict]:
    """Build display records with 1-based cell indices."""
    records: list[dict] = []
    line = 1
    for i, cell in enumerate(cells):
        source: str = cell["source"] if isinstance(cell, dict) else cell.source
        cell_type: str = cell["cell_type"] if isinstance(cell, dict) else cell.cell_type
        meta = cell.get("metadata", {}) if isinstance(cell, dict) else dict(cell.get("metadata", {}))
        label_val: str | None = meta.get("label") or None
        line_count = source.count("\n") + (1 if source else 0)
        records.append({
            "index": i + 1,  # 1-based for all user-facing output
            "cell_type": cell_type,
            "label": label_val,
            "source": source,
            "start_line": line,
        })
        line += line_count
    return records


def main() -> None:
    args = sys.argv[1:]
    if not args or "--help" in args or "-h" in args:
        print(__doc__)
        sys.exit(0)

    as_json = "--json" in args

    cell_index: int | None = None  # 1-based when set
    label: str | None = None

    if "--cell" in args:
        ci = args.index("--cell")
        if ci + 1 >= len(args):
            print("Error: --cell requires an index argument.", file=sys.stderr)
            sys.exit(1)
        cell_index = int(args[ci + 1])  # user supplies 1-based index

    if "--label" in args:
        li = args.index("--label")
        if li + 1 >= len(args):
            print("Error: --label requires a value argument.", file=sys.stderr)
            sys.exit(1)
        label = args[li + 1]

    skip_next = False
    file_args = []
    for a in args:
        if skip_next:
            skip_next = False
            continue
        if a in ("--cell", "--label"):
            skip_next = True
            continue
        if not a.startswith("--"):
            file_args.append(a)

    if not file_args:
        print("Error: no notebook path specified.", file=sys.stderr)
        sys.exit(1)

    path = Path(file_args[0])
    if not path.exists():
        print(f"Error: {path} not found.", file=sys.stderr)
        sys.exit(1)

    try:
        rel_path = path.resolve().relative_to(BASE_DIR)
    except ValueError:
        rel_path = path

    cells = _fetch_via_api(str(rel_path).replace("\\", "/"))
    if cells is None:
        if _ensure_server():
            cells = _fetch_via_api(str(rel_path).replace("\\", "/"))
    if cells is None:
        print("Warning: Jupyter server not reachable — falling back to nbformat.", file=sys.stderr)
        cells = _fetch_via_nbformat(path)

    if label is not None:
        # _resolve_label returns 0-based; convert to 1-based for record lookup
        cell_index = _resolve_label(cells, label) + 1

    records = _build_records(cells)  # records use 1-based indices

    if cell_index is not None:
        matching = [r for r in records if r["index"] == cell_index]
        if not matching:
            print(
                f"Error: cell index {cell_index} not found (notebook has {len(records)} cells, indices 1–{len(records)}).",
                file=sys.stderr)
            sys.exit(1)
        records = matching

    if as_json:
        print(json.dumps(records, indent=2))
    else:
        print(str(path))
        for rec in records:
            source_lines = rec["source"].splitlines()
            line_info = f"  (lines {rec['start_line']}–{rec['start_line'] + len(source_lines) - 1})" if source_lines else ""
            label_part = f" [{rec['label']}]" if rec.get('label') else ""
            print(f"  [{rec['index']}] {rec['cell_type']}{label_part}{line_info}")
            for src_line in source_lines:
                print(f"      {src_line}")


if __name__ == "__main__":
    main()
