#!/usr/bin/env -S uv run python
"""
DESCRIPTION: Print all active plans in plans/ (excluding archive/ and plan_standards.md) with headers.

Usage: uv run python ai_bin/plans dump [<name> ...]

  <name>   Optional substring filter(s) on plan filename. If omitted, all plans are printed.
"""
from __future__ import annotations

import os as _os

if _os.environ.get("AIBIN_DISPATCHER") != "1":
    print("ERROR: This script must be run via its dispatcher (e.g. uv run python ai_bin/nb ...). "
          "Direct invocation is not permitted.", file=__import__('sys').stderr)
    __import__('sys').exit(1)

import sys
from pathlib import Path

PROJECT_ROOT = Path(__file__).resolve().parent.parent.parent
PLANS_DIR = PROJECT_ROOT / "plans"
EXCLUDE_NAMES = {"plan_standards.md"}


def main() -> None:
    if "--help" in sys.argv or "-h" in sys.argv:
        print(__doc__)
        return

    filters = [a for a in sys.argv[1:] if not a.startswith("-")]

    plans = sorted(
        p for p in PLANS_DIR.glob("*.md")
        if p.name not in EXCLUDE_NAMES
    )

    if filters:
        plans = [p for p in plans if any(f in p.name for f in filters)]

    if not plans:
        print("No active plans found.")
        return

    for plan in plans:
        print(f"=== plans/{plan.name} ===")
        print(plan.read_text(encoding="utf-8"))


if __name__ == "__main__":
    main()
