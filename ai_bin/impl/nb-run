#!/usr/bin/env -S uv run python
"""
DESCRIPTION: Execute all code cells of a notebook via Jupyter Server REST API (WebSocket).
Usage: uv run python ai_bin/nb run <notebook.ipynb> [--help]
Requires: Jupyter server running on port 18888 (start with: uv run python ai_bin/jupyter start)
"""
from __future__ import annotations

import os as _os

if _os.environ.get("AIBIN_DISPATCHER") != "1":
    print("ERROR: This script must be run via its dispatcher (e.g. uv run python ai_bin/nb ...). "
          "Direct invocation is not permitted.", file=__import__('sys').stderr)
    __import__('sys').exit(1)
import json
import sys
import time
from pathlib import Path
import requests

BASE_DIR = Path(__file__).resolve().parent.parent.parent  # project root
PORT = 18888
BASE_URL = f"http://localhost:{PORT}"


def main() -> None:
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help"):
        print(__doc__)
        sys.exit(0)

    nb_path = args[0]

    # Verify server is up
    try:
        requests.get(f"{BASE_URL}/api", timeout=5).raise_for_status()
    except Exception as e:
        print(f"ERROR: Jupyter server not reachable at {BASE_URL}: {e}", file=sys.stderr)
        print("Start it with: uv run python ai_bin/jupyter start", file=sys.stderr)
        sys.exit(1)

    # Fetch notebook
    r = requests.get(f"{BASE_URL}/api/contents/{nb_path}")
    r.raise_for_status()
    nb = r.json()
    cells = nb["content"]["cells"]
    code_cells = [(i, c) for i, c in enumerate(cells) if c["cell_type"] == "code"]
    print(f"Notebook: {nb_path}")
    print(f"Executing {len(code_cells)} code cell(s)...")

    # Start kernel session
    sess_resp = requests.post(f"{BASE_URL}/api/sessions", json={
        "path": nb_path,
        "type": "notebook",
        "kernel": {"name": "python3"},
    })
    sess_resp.raise_for_status()
    sess = sess_resp.json()
    kernel_id = sess["kernel"]["id"]
    sess_id = sess["id"]
    print(f"Kernel: {kernel_id}")

    try:
        import websocket
    except ImportError:
        print("ERROR: websocket-client not installed. Run: uv add websocket-client", file=sys.stderr)
        requests.delete(f"{BASE_URL}/api/sessions/{sess_id}")
        sys.exit(1)

    ws_url = f"ws://localhost:{PORT}/api/kernels/{kernel_id}/channels"
    ws = websocket.create_connection(ws_url, timeout=30)

    # Inject project root into sys.path so imports work regardless of kernel cwd
    project_root = str(BASE_DIR)
    bootstrap_src = (
        f"import sys as _sys\n"
        f"if {project_root!r} not in _sys.path:\n"
        f"    _sys.path.insert(0, {project_root!r})\n"
    )
    # Send bootstrap silently
    _bid = f"bootstrap_{int(time.time() * 1000)}"
    _bmsg = {
        "header": {"msg_id": _bid, "msg_type": "execute_request", "version": "5.3",
                   "username": "agent", "session": _bid, "date": ""},
        "parent_header": {}, "metadata": {},
        "content": {"code": bootstrap_src, "silent": True, "store_history": False,
                    "user_expressions": {}, "allow_stdin": False},
        "channel": "shell",
    }
    ws.send(json.dumps(_bmsg))
    while True:
        _r = json.loads(ws.recv())
        if _r.get("parent_header", {}).get("msg_id") == _bid:
            if _r.get("header", {}).get("msg_type") == "execute_reply":
                break

    success = True
    for cell_num, (cell_idx, cell) in enumerate(code_cells, start=1):
        src = cell["source"] if isinstance(cell["source"], str) else "".join(cell["source"])
        if not src.strip():
            continue

        msg_id = f"exec_{cell_idx}_{int(time.time() * 1000)}"
        msg = {
            "header": {
                "msg_id": msg_id,
                "msg_type": "execute_request",
                "version": "5.3",
                "username": "agent",
                "session": msg_id,
                "date": "",
            },
            "parent_header": {},
            "metadata": {},
            "content": {
                "code": src,
                "silent": False,
                "store_history": True,
                "user_expressions": {},
                "allow_stdin": False,
            },
            "channel": "shell",
        }
        ws.send(json.dumps(msg))
        print(f"\n[Cell {cell_num}/{len(code_cells)} idx={cell_idx}]")

        while True:
            raw = ws.recv()
            resp = json.loads(raw)
            if resp.get("parent_header", {}).get("msg_id") != msg_id:
                continue
            mt = resp.get("header", {}).get("msg_type", "")
            if mt == "stream":
                text = resp["content"].get("text", "").rstrip()
                if text:
                    print(f"  {text}")
            elif mt in ("display_data", "execute_result"):
                data = resp["content"].get("data", {})
                text = data.get("text/plain", "").rstrip()
                if text:
                    print(f"  {text}")
            elif mt == "error":
                ename = resp["content"].get("ename", "")
                evalue = resp["content"].get("evalue", "")
                print(f"  ERROR: {ename}: {evalue}", file=sys.stderr)
                for line in resp["content"].get("traceback", []):
                    print(f"  {line}", file=sys.stderr)
                success = False
                break
            elif mt == "execute_reply":
                status = resp["content"].get("status", "")
                if status == "error":
                    success = False
                break

        if not success:
            print("\nAborting: cell execution failed.", file=sys.stderr)
            break

    ws.close()
    requests.delete(f"{BASE_URL}/api/sessions/{sess_id}")
    if success:
        print("\nAll cells executed successfully.")
    else:
        sys.exit(1)


if __name__ == "__main__":
    main()
