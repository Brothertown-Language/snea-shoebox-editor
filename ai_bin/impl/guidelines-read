#!/usr/bin/env -S uv run python
"""
DESCRIPTION: Print the contents of a guideline file from .opencode/guidelines/.
Usage: uv run python ai_bin/guidelines read <filename>
Example: uv run python ai_bin/guidelines read 041
Note: Prefer 3-digit shorthand when available (for example `041` instead of full filename).
"""
from __future__ import annotations
import os as _os
if _os.environ.get("AIBIN_DISPATCHER") != "1":
    print("ERROR: This script must be run via its dispatcher (e.g. uv run python ai_bin/nb ...). "
          "Direct invocation is not permitted.", file=__import__('sys').stderr)
    __import__('sys').exit(1)
import sys
from pathlib import Path

BASE_DIR = Path(__file__).resolve().parent.parent.parent
GUIDELINES_DIR = BASE_DIR / ".opencode" / "guidelines"
PERSONAS_DIR = BASE_DIR / ".opencode" / "personas"


def _resolve_guideline_path(name: str) -> Path | None:
    junie_dir = BASE_DIR / ".opencode"
    candidates: list[Path] = [
        GUIDELINES_DIR / name,
        junie_dir / name,
    ]
    if not name.endswith(".md"):
        candidates.extend([
            GUIDELINES_DIR / f"{name}.md",
            junie_dir / f"{name}.md",
        ])

    for candidate in candidates:
        if candidate.exists() and candidate.is_file():
            return candidate

    if len(name) == 3 and name.isdigit():
        matches = sorted(path for path in GUIDELINES_DIR.glob(f"{name}*.md") if path.is_file())
        if len(matches) == 1:
            return matches[0]
        if len(matches) > 1:
            print(f"Error: multiple guideline files found for prefix '{name}':", file=sys.stderr)
            for path in matches:
                print(f"  {path.name}", file=sys.stderr)
            sys.exit(1)

    return None


def main() -> None:
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help"):
        print(__doc__)
        files = sorted(GUIDELINES_DIR.glob("*.md"))
        if files:
            print("Available guideline files:")
            for f in files:
                print(f"  {f.name}")
        sys.exit(0)

    name = args[0]
    if name.strip().lower() in {"persona", "personas"}:
        print("Error: persona name is required, use personas/<name>.md", file=sys.stderr)
        sys.exit(1)

    # Support subdirectory prefixes like "personas/guideline-auditor.md"

    persona_relative: str | None = None
    if name.startswith("personas/"):
        persona_relative = name.removeprefix("personas/")
    elif name.startswith(".opencode/personas/"):
        persona_relative = name.removeprefix(".opencode/personas/")

    if persona_relative is not None:
        persona_candidate = PERSONAS_DIR / persona_relative
        if persona_candidate.exists():
            print(persona_candidate.read_text())
            return

        persona_name = persona_relative
        if not persona_name.endswith(".md"):
            persona_name += ".md"

        persona_candidate_with_ext = PERSONAS_DIR / persona_name
        if persona_candidate_with_ext.exists():
            print(persona_candidate_with_ext.read_text())
            return

        print(f"Error: persona file not found: {name}", file=sys.stderr)
        print(f"Available files in {PERSONAS_DIR.relative_to(BASE_DIR)}:", file=sys.stderr)
        for f in sorted(PERSONAS_DIR.glob("*.md")):
            print(f"  {f.name}", file=sys.stderr)
        sys.exit(1)

    path = _resolve_guideline_path(name)
    if path is None:
        print(f"Error: guideline file not found: {name}", file=sys.stderr)
        print(f"Available files in {GUIDELINES_DIR.relative_to(BASE_DIR)}:", file=sys.stderr)
        for f in sorted(GUIDELINES_DIR.glob("*.md")):
            print(f"  {f.name}", file=sys.stderr)
        sys.exit(1)

    print(path.read_text())


if __name__ == "__main__":
    main()
