#!/usr/bin/env -S uv run python
"""
DESCRIPTION: Insert a new cell (code or markdown) into a .ipynb notebook at a specific position.
Usage: uv run python ai_bin/nb cell insert <notebook.ipynb> (--after <index> | --after-label <label>) [--type code|markdown] (--source <text> | --source-file <path>) [--metadata <json>] [--help]
Primary:  Jupyter Server REST API on port 18888 (GET then PUT /api/contents/<path>).
Fallback: nbformat.read + mutate + nbformat.write when server is not reachable.

Inserts the new cell after the given 1-based cell index or after the cell with the given label.
Prints the index of the new cell.
"""
from __future__ import annotations

import os as _os

if _os.environ.get("AIBIN_DISPATCHER") != "1":
    print("ERROR: This script must be run via its dispatcher (e.g. uv run python ai_bin/nb ...). "
          "Direct invocation is not permitted.", file=__import__('sys').stderr)
    __import__('sys').exit(1)

import subprocess
import sys
import time
from pathlib import Path

import nbformat
import requests

BASE_DIR = Path(__file__).resolve().parent.parent.parent  # project root
PORT = 18888
BASE_URL = f"http://localhost:{PORT}"


def _is_port_listening() -> bool:
    result = subprocess.run(["ss", "-tlnp"], capture_output=True, text=True)
    return f":{PORT}" in result.stdout


def _ensure_server() -> bool:
    if _is_port_listening():
        return True
    result = subprocess.run(
        ["uv", "run", "jupyter", "server", "--version"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        return False
    log = BASE_DIR / "tmp" / "jupyter.log"
    log.parent.mkdir(parents=True, exist_ok=True)
    subprocess.Popen(
        ["uv", "run", "jupyter", "server", "--no-browser",
         f"--port={PORT}", "--IdentityProvider.token=",
         "--ServerApp.disable_check_xsrf=True"],
        stdout=open(log, "a"), stderr=subprocess.STDOUT, cwd=str(BASE_DIR),
    )
    for _ in range(16):
        time.sleep(0.5)
        if _is_port_listening():
            return True
    return False


def _rel(path: Path) -> str:
    try:
        return str(path.resolve().relative_to(BASE_DIR)).replace("\\", "/")
    except ValueError:
        return str(path).replace("\\", "/")


def _make_cell(cell_type: str, source: str, metadata: dict | None = None) -> dict:
    if cell_type == "markdown":
        cell = nbformat.v4.new_markdown_cell(source)
    else:
        cell = nbformat.v4.new_code_cell(source)
    if metadata:
        cell["metadata"].update(metadata)
    return cell


def _resolve_label(cells: list, label: str) -> int:
    """Return 1-based index of the cell whose metadata label matches, or raise."""
    for i, cell in enumerate(cells):
        if cell.get("metadata", {}).get("label") == label:
            return i + 1
    raise ValueError(f"No cell with label '{label}' found in notebook.")


def _insert_via_api(rel_path: str, after: int, cell_type: str, source: str, metadata: dict | None = None,
                    after_label: str | None = None) -> int | None:
    try:
        r = requests.get(f"{BASE_URL}/api/contents/{rel_path}?type=notebook", timeout=5)
        r.raise_for_status()
        payload = r.json()
        cells = payload["content"]["cells"]
        if after_label is not None:
            after = _resolve_label(cells, after_label)
        insert_pos = after  # after is 1-based, so insert at index `after`
        cells.insert(insert_pos, _make_cell(cell_type, source, metadata))
        put = requests.put(
            f"{BASE_URL}/api/contents/{rel_path}",
            json={"type": "notebook", "content": payload["content"]},
            timeout=10,
        )
        put.raise_for_status()
        return insert_pos + 1  # 1-based index of new cell
    except SystemExit:
        raise
    except requests.exceptions.RequestException:
        return None


def _insert_via_nbformat(path: Path, after: int, cell_type: str, source: str, metadata: dict | None = None,
                         after_label: str | None = None) -> int:
    with path.open(encoding="utf-8") as f:
        nb = nbformat.read(f, as_version=4)
    if after_label is not None:
        after = _resolve_label(nb.cells, after_label)
    insert_pos = after  # after is 1-based, insert at that 0-based index
    nb.cells.insert(insert_pos, _make_cell(cell_type, source, metadata))
    with path.open("w", encoding="utf-8") as f:
        nbformat.write(nb, f)
    return insert_pos + 1  # 1-based index of new cell


def main() -> None:
    args = sys.argv[1:]
    if not args or "--help" in args or "-h" in args:
        print(__doc__)
        sys.exit(0)

    nb_path: Path | None = None
    cell_type: str = "code"
    source: str | None = None
    after: int | None = None
    after_label: str | None = None
    metadata: dict | None = None

    i = 0
    while i < len(args):
        arg = args[i]
        if arg == "--type":
            i += 1
            cell_type = args[i] if i < len(args) else "code"
        elif arg == "--after":
            i += 1
            after = int(args[i]) if i < len(args) else None
        elif arg == "--after-label":
            i += 1
            after_label = args[i] if i < len(args) else None
        elif arg == "--source":
            i += 1
            source = args[i] if i < len(args) else None
        elif arg == "--source-file":
            i += 1
            source = Path(args[i]).read_text(encoding="utf-8") if i < len(args) else None
        elif arg == "--metadata":
            i += 1
            import json as _json
            metadata = _json.loads(args[i]) if i < len(args) else None
        elif not arg.startswith("--"):
            nb_path = Path(arg)
        i += 1

    if nb_path is None:
        print("Error: no notebook path specified.", file=sys.stderr)
        sys.exit(1)
    if not nb_path.exists():
        print(f"Error: {nb_path} not found.", file=sys.stderr)
        sys.exit(1)
    if source is None:
        print("Error: --source or --source-file is required.", file=sys.stderr)
        sys.exit(1)
    if after is None and after_label is None:
        print("Error: --after <index> or --after-label <label> is required.", file=sys.stderr)
        sys.exit(1)
    if cell_type not in ("code", "markdown"):
        print("Error: --type must be 'code' or 'markdown'.", file=sys.stderr)
        sys.exit(1)

    rel_path = _rel(nb_path)
    idx = _insert_via_api(rel_path, after or 0, cell_type, source, metadata, after_label)
    if idx is None:
        if _ensure_server():
            idx = _insert_via_api(rel_path, after or 0, cell_type, source, metadata, after_label)
        if idx is None:
            print("Warning: Jupyter server not reachable — falling back to nbformat.", file=sys.stderr)
            idx = _insert_via_nbformat(nb_path, after or 0, cell_type, source, metadata, after_label)

    print(f"Inserted {cell_type} cell at index {idx} in {nb_path}")


if __name__ == "__main__":
    main()
