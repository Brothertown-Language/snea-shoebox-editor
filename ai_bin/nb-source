#!/usr/bin/env -S uv run python
"""
DESCRIPTION: Print all cell sources from a notebook with cell index, type, and line numbers.

Usage: uv run python ai_bin/nb-source <notebook.ipynb> [--json] [--help]

Primary:  Jupyter Server REST API on port 18888 (GET /api/contents/<path>).
Fallback: nbformat.read(..., as_version=4) when server is not reachable.
"""
from __future__ import annotations

import json
import sys
from pathlib import Path

import requests
import nbformat

BASE_DIR = Path(__file__).resolve().parent.parent  # project root
PORT = 18888
BASE_URL = f"http://localhost:{PORT}"


def _fetch_via_api(rel_path: str) -> list[dict] | None:
    try:
        r = requests.get(f"{BASE_URL}/api/contents/{rel_path}?type=notebook", timeout=3)
        r.raise_for_status()
        cells = r.json()["content"]["cells"]
        return cells
    except Exception:
        return None


def _fetch_via_nbformat(path: Path) -> list[dict]:
    with path.open(encoding="utf-8") as f:
        nb = nbformat.read(f, as_version=4)
    return nb.cells


def _build_records(cells: list) -> list[dict]:
    records: list[dict] = []
    line = 1
    for i, cell in enumerate(cells):
        source: str = cell["source"] if isinstance(cell, dict) else cell.source
        cell_type: str = cell["cell_type"] if isinstance(cell, dict) else cell.cell_type
        line_count = source.count("\n") + (1 if source else 0)
        records.append({
            "index": i,
            "cell_type": cell_type,
            "source": source,
            "start_line": line,
        })
        line += line_count
    return records


def main() -> None:
    args = sys.argv[1:]
    if not args or "--help" in args or "-h" in args:
        print(__doc__)
        sys.exit(0)

    as_json = "--json" in args
    file_args = [a for a in args if not a.startswith("--")]

    if not file_args:
        print("Error: no notebook path specified.", file=sys.stderr)
        sys.exit(1)

    path = Path(file_args[0])
    if not path.exists():
        print(f"Error: {path} not found.", file=sys.stderr)
        sys.exit(1)

    try:
        rel_path = path.resolve().relative_to(BASE_DIR)
    except ValueError:
        rel_path = path

    cells = _fetch_via_api(str(rel_path).replace("\\", "/"))
    if cells is None:
        print("Warning: Jupyter server not reachable — falling back to nbformat.", file=sys.stderr)
        cells = _fetch_via_nbformat(path)

    records = _build_records(cells)

    if as_json:
        print(json.dumps(records, indent=2))
    else:
        print(str(path))
        for rec in records:
            source_lines = rec["source"].splitlines()
            line_info = f"  (lines {rec['start_line']}–{rec['start_line'] + len(source_lines) - 1})" if source_lines else ""
            print(f"  [{rec['index']}] {rec['cell_type']}{line_info}")
            for src_line in source_lines:
                print(f"      {src_line}")


if __name__ == "__main__":
    main()
