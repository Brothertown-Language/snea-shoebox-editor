#!/usr/bin/env -S uv run python
"""
DESCRIPTION: Initialize AI session — outputs primary guidelines, available tools, and memory.
Usage: uv run python ai_bin/start
"""
from __future__ import annotations

import importlib.metadata
import subprocess
import sys
from pathlib import Path

BASE_DIR = Path(__file__).resolve().parent
REPO_ROOT = BASE_DIR.parent
GUIDELINES_DIR = REPO_ROOT / ".junie" / "guidelines"
MEMORY_FILE = REPO_ROOT / ".junie" / "memory.md"


def section(title: str) -> None:
    bar = "=" * 72
    print(f"\n{bar}")
    print(f"  {title}")
    print(f"{bar}\n")


def main() -> None:
    # --- Guidelines ---
    # Always load the root guideline (00-session-init.md); topic guidelines are loaded on demand.
    section("PRIMARY GUIDELINES")
    root_guideline = GUIDELINES_DIR / "00-session-init.md"
    if root_guideline.exists():
        print(f"### {root_guideline.name}\n")
        print(root_guideline.read_text(encoding="utf-8"))
        print()

    # --- Plan standards (reference only; load on demand when writing plans) ---
    section("PLAN STANDARDS")
    print("📋 Read `plans/plan_standards.md` before writing or updating any plan.")

    # --- Agent memory (reference only; load on demand) ---
    section("AGENT MEMORY")
    print("🧠 Memory file: `.junie/memory.md` — read before starting any task; update after completing any task.")

    # --- Available tools ---
    section("AVAILABLE AGENT TOOLS (ai_bin/help)")
    result = subprocess.run(
        [sys.executable, str(BASE_DIR / "help")],
        capture_output=True,
        text=True,
    )
    print(result.stdout)
    if result.stderr:
        print(result.stderr, file=sys.stderr)

    # --- Python dev tools ---
    section("AVAILABLE PYTHON DEV TOOLS")
    dev_tools = [
        # linting / style
        "ruff", "pyflakes", "mypy", "black", "isort", "pylint", "flake8", "bandit",
        # testing / property-based / mutation
        "pytest", "coverage", "hypothesis", "tox", "nox",
        # refactoring
        "rope",
        # dead-code / static analysis
        "vulture", "pyright",
        # dependency / call graphs
        "pydeps",
        # profiling / performance
        "snakeviz", "py-spy", "memray",
    ]
    available = []
    for tool in dev_tools:
        check = subprocess.run(
            [sys.executable, "-m", tool, "--version"],
            capture_output=True,
            text=True,
        )
        if check.returncode == 0:
            version_line = (check.stdout or check.stderr).strip().splitlines()[0]
            available.append(f"  {tool:<12} — {version_line}")
        else:
            # try as a standalone binary
            which = subprocess.run(["which", tool], capture_output=True, text=True)
            if which.returncode == 0:
                available.append(f"  {tool:<12} — (available via PATH)")
            else:
                # try importable package (e.g. rope has no CLI entry point)
                try:
                    ver = importlib.metadata.version(tool)
                    available.append(f"  {tool:<12} — {ver} (importable)")
                except importlib.metadata.PackageNotFoundError:
                    pass
    if available:
        print("\n".join(available))
    else:
        print("  (none detected)")

    # --- OS info ---
    try:
        lsb = subprocess.run(
            ["lsb_release", "-a"],
            capture_output=True,
            text=True,
        )
        if lsb.returncode == 0 and lsb.stdout.strip():
            print(lsb.stdout.strip())
    except FileNotFoundError:
        pass


if __name__ == "__main__":
    main()
