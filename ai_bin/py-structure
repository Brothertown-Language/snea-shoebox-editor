#!/usr/bin/env -S uv run python
"""
DESCRIPTION: Show classes, methods, and functions with line numbers for a Python file.
Usage: uv run python ai_bin/py-structure <file.py> [--json]
"""
from __future__ import annotations

import ast
import json
import sys
from pathlib import Path


def extract_structure(path: Path) -> list[dict]:
    text = path.read_text(encoding="utf-8")
    tree = ast.parse(text, filename=str(path))
    results: list[dict] = []

    for node in ast.walk(tree):
        if isinstance(node, ast.ClassDef):
            methods: list[dict] = []
            for child in node.body:
                if isinstance(child, ast.FunctionDef | ast.AsyncFunctionDef):
                    methods.append({"kind": "method", "name": child.name, "line": child.lineno})
            results.append({"kind": "class", "name": node.name, "line": node.lineno, "methods": methods})

    top_level_classes = {node.name for node in ast.walk(tree) if isinstance(node, ast.ClassDef)}
    for node in ast.iter_child_nodes(tree):
        if isinstance(node, ast.FunctionDef | ast.AsyncFunctionDef):
            if node.name not in top_level_classes:
                results.append({"kind": "function", "name": node.name, "line": node.lineno, "methods": []})

    results.sort(key=lambda r: r["line"])
    return results


def print_structure(path: Path, structure: list[dict]) -> None:
    print(str(path))
    for entry in structure:
        if entry["kind"] == "class":
            print(f"  class {entry['name']:<30} line {entry['line']}")
            for method in entry["methods"]:
                print(f"    method {method['name']:<28} line {method['line']}")
        else:
            print(f"  function {entry['name']:<28} line {entry['line']}")


def main() -> None:
    args = sys.argv[1:]
    if not args or "--help" in args or "-h" in args:
        print(__doc__)
        sys.exit(0)

    as_json = "--json" in args
    file_args = [a for a in args if not a.startswith("--")]

    if not file_args:
        print("Error: no file specified.", file=sys.stderr)
        sys.exit(1)

    path = Path(file_args[0])
    if not path.exists():
        print(f"Error: {path} not found.", file=sys.stderr)
        sys.exit(1)

    structure = extract_structure(path)

    if as_json:
        print(json.dumps({"file": str(path), "structure": structure}, indent=2))
    else:
        print_structure(path, structure)


if __name__ == "__main__":
    main()
