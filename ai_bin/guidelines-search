#!/usr/bin/env -S uv run python
"""
DESCRIPTION: Search .junie guideline files using hybrid BM25 + semantic re-ranking (default),
             or BM25-only / semantic-only via flags.

Usage: uv run python ai_bin/guidelines-search <term> [options]
       uv run python ai_bin/guidelines-search --bm25 <term> [options]  (BM25-only; no model needed)

Arguments:
  <term>            Search term (case-insensitive)
  --file <filename> Restrict search to one guideline file (e.g., 03-tool-usage.md)
  --context <n>     Lines of surrounding context to print (default: 3)
  --top <n>         Max results to show (default: 10)
  --bm25            BM25-only mode (fast, no model load)
  --semantic        Semantic-only mode (cosine similarity via sentence-transformers)
  --alpha <float>   Hybrid weight for BM25 vs semantic (default: 0.5); ignored in single-mode
  --help / -h       Print this help and exit

Modes:
  default           Hybrid re-ranking: alpha * bm25_norm + (1 - alpha) * semantic_sim
  --bm25            BM25 only — exact/keyword matching, no model required
  --semantic        Semantic only — embedding cosine similarity
  --bm25 --semantic Error: mutually exclusive

Note: hybrid and --semantic modes require sentence-transformers (~500 MB first download, slow
cold start). Model: all-MiniLM-L6-v2.

Exit codes: 0 = matches found, 1 = no matches, 2 = error
"""
from __future__ import annotations

import math
import re
import sys
from pathlib import Path

ROOT = Path(__file__).parent.parent
GUIDELINES_ROOT = ROOT / ".junie"
DEFAULT_MODEL = "all-MiniLM-L6-v2"


def load_corpus(file_filter: str | None) -> list[tuple[Path, int, str]]:
    """Return list of (path, line_number_1based, line_text)."""
    if file_filter:
        candidates = [GUIDELINES_ROOT / "guidelines" / file_filter]
        if not candidates[0].exists():
            candidates = [GUIDELINES_ROOT / file_filter]
    else:
        candidates = [
            GUIDELINES_ROOT / "guidelines.md",
            *sorted((GUIDELINES_ROOT / "guidelines").glob("*.md")),
        ]
    chunks: list[tuple[Path, int, str]] = []
    for path in candidates:
        if not path.exists():
            print(f"ERROR: {path} not found.", file=sys.stderr)
            sys.exit(2)
        for i, line in enumerate(path.read_text(encoding="utf-8").splitlines(), 1):
            chunks.append((path, i, line))
    return chunks


def tokenize(text: str) -> list[str]:
    return re.findall(r"[a-z0-9]+", text.lower())


def bm25_score(
    query_tokens: list[str],
    doc_tokens: list[str],
    idf: dict[str, float],
    k1: float = 1.5,
    b: float = 0.75,
    avg_dl: float = 10.0,
) -> float:
    dl = len(doc_tokens)
    tf_map: dict[str, int] = {}
    for t in doc_tokens:
        tf_map[t] = tf_map.get(t, 0) + 1
    score = 0.0
    for qt in query_tokens:
        if qt not in idf:
            continue
        tf = tf_map.get(qt, 0)
        numerator = tf * (k1 + 1)
        denominator = tf + k1 * (1 - b + b * dl / avg_dl)
        score += idf[qt] * (numerator / denominator if denominator else 0)
    return score


def compute_idf(corpus_tokens: list[list[str]]) -> dict[str, float]:
    n = len(corpus_tokens)
    df: dict[str, int] = {}
    for tokens in corpus_tokens:
        for t in set(tokens):
            df[t] = df.get(t, 0) + 1
    return {t: math.log((n - f + 0.5) / (f + 0.5) + 1) for t, f in df.items()}


def bm25_scores_raw(
    query_tokens: list[str],
    corpus_tokens: list[list[str]],
    idf: dict[str, float],
    avg_dl: float,
) -> list[float]:
    return [
        bm25_score(query_tokens, doc_tokens, idf, avg_dl=avg_dl)
        for doc_tokens in corpus_tokens
    ]


def semantic_scores(lines: list[str], query: str) -> list[float]:
    """Return cosine similarity scores in [0, 1] for each line vs query."""
    from sentence_transformers import SentenceTransformer, util  # type: ignore[import]

    model = SentenceTransformer(DEFAULT_MODEL)
    corpus_embeddings = model.encode(lines, convert_to_tensor=True, show_progress_bar=False)
    query_embedding = model.encode(query, convert_to_tensor=True, show_progress_bar=False)
    cosine_scores = util.cos_sim(query_embedding, corpus_embeddings)[0]
    return cosine_scores.tolist()


def hybrid_scores(
    query_tokens: list[str],
    corpus_tokens: list[list[str]],
    idf: dict[str, float],
    avg_dl: float,
    lines: list[str],
    query: str,
    alpha: float,
) -> list[float]:
    """Combine normalised BM25 and semantic cosine scores."""
    raw_bm25 = bm25_scores_raw(query_tokens, corpus_tokens, idf, avg_dl)
    min_b, max_b = min(raw_bm25), max(raw_bm25)
    span_b = max_b - min_b if max_b != min_b else 1.0
    norm_bm25 = [(s - min_b) / span_b for s in raw_bm25]

    sem = semantic_scores(lines, query)
    min_s, max_s = min(sem), max(sem)
    span_s = max_s - min_s if max_s != min_s else 1.0
    norm_sem = [(s - min_s) / span_s for s in sem]

    return [alpha * b + (1.0 - alpha) * s for b, s in zip(norm_bm25, norm_sem)]


def main() -> None:
    args = sys.argv[1:]
    if not args or "--help" in args or "-h" in args:
        print(__doc__)
        sys.exit(0)

    file_filter: str | None = None
    context_n = 3
    top_n = 10
    alpha = 0.5
    mode_bm25 = False
    mode_semantic = False
    term_parts: list[str] = []

    i = 0
    while i < len(args):
        if args[i] == "--file" and i + 1 < len(args):
            file_filter = args[i + 1]
            i += 2
        elif args[i] == "--context" and i + 1 < len(args):
            context_n = int(args[i + 1])
            i += 2
        elif args[i] == "--top" and i + 1 < len(args):
            top_n = int(args[i + 1])
            i += 2
        elif args[i] == "--alpha" and i + 1 < len(args):
            alpha = float(args[i + 1])
            i += 2
        elif args[i] == "--bm25":
            mode_bm25 = True
            i += 1
        elif args[i] == "--semantic":
            mode_semantic = True
            i += 1
        else:
            term_parts.append(args[i])
            i += 1

    if mode_bm25 and mode_semantic:
        print("ERROR: --bm25 and --semantic are mutually exclusive.", file=sys.stderr)
        sys.exit(2)

    term = " ".join(term_parts)
    if not term:
        print("ERROR: search term required.", file=sys.stderr)
        sys.exit(2)

    chunks = load_corpus(file_filter)
    all_lines = [line for _, _, line in chunks]
    corpus_tokens = [tokenize(line) for line in all_lines]
    avg_dl = sum(len(t) for t in corpus_tokens) / max(len(corpus_tokens), 1)
    idf = compute_idf(corpus_tokens)
    query_tokens = tokenize(term)

    if mode_bm25:
        raw = bm25_scores_raw(query_tokens, corpus_tokens, idf, avg_dl)
        scored = sorted(enumerate(raw), key=lambda x: x[1], reverse=True)
        top = [(s, idx) for idx, s in scored[:top_n] if s > 0]
    elif mode_semantic:
        sem = semantic_scores(all_lines, term)
        scored = sorted(enumerate(sem), key=lambda x: x[1], reverse=True)
        top = [(s, idx) for idx, s in scored[:top_n] if s > 0]
    else:
        hyb = hybrid_scores(query_tokens, corpus_tokens, idf, avg_dl, all_lines, term, alpha)
        scored = sorted(enumerate(hyb), key=lambda x: x[1], reverse=True)
        top = [(s, idx) for idx, s in scored[:top_n] if s > 0]

    if not top:
        print(f"No matches for: {term!r}")
        sys.exit(1)

    for score, idx in top:
        path, lineno, _ = chunks[idx]
        rel = path.relative_to(GUIDELINES_ROOT)
        start = max(0, idx - context_n)
        end = min(len(all_lines), idx + context_n + 1)
        print(f"\n=== {rel}:{lineno} (score={score:.2f}) ===")
        for ci in range(start, end):
            prefix = ">>>" if ci == idx else "   "
            print(f"{prefix} {chunks[ci][1]:4d}: {all_lines[ci]}")


if __name__ == "__main__":
    main()
