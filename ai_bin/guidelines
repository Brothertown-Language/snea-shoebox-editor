#!/usr/bin/env -S uv run python
"""
DESCRIPTION: Dispatcher for guideline operations. Delegates to implementation scripts.
Usage: uv run python ai_bin/guidelines <command> [args]
Commands:
  read <file>     Read a guideline file (supports 3-digit shorthand)
  show <section>  Show a specific section
  edit <file>     Edit a guideline file
  search <query>  Search guidelines (BM25 + semantic)
  --list-sections List all available sections

Note: This dispatcher prevents direct invocation of implementation scripts.
"""
from __future__ import annotations
import os
import sys
import subprocess
from pathlib import Path

BASE_DIR = Path(__file__).resolve().parent.parent
GUIDELINES_DIR = BASE_DIR / ".opencode" / "guidelines"
IMPL_DIR = Path(__file__).resolve().parent / "impl"

COMMANDS = {
    "read": IMPL_DIR / "guidelines-read",
    "show": IMPL_DIR / "guidelines-show",
    "edit": IMPL_DIR / "guidelines-edit",
    "search": IMPL_DIR / "guidelines-search",
}


def print_help() -> None:
    print(__doc__)
    files = sorted(GUIDELINES_DIR.glob("*.md"))
    if files:
        print("\nAvailable guideline files:")
        for f in files:
            print(f"  {f.name}")


def main() -> None:
    args = sys.argv[1:]
    
    if not args or args[0] in ("-h", "--help"):
        print_help()
        sys.exit(0)
    
    if "--list-sections" in args:
        print("Listing sections is supported via the 'show' command.")
        print("Usage: uv run python ai_bin/guidelines show <section-name>")
        sys.exit(0)
    
    command = args[0]
    
    if command not in COMMANDS:
        print(f"Error: Unknown command '{command}'", file=sys.stderr)
        print_help()
        sys.exit(1)
    
    impl_path = COMMANDS[command]
    if not impl_path.exists():
        print(f"Error: Implementation not found: {impl_path}", file=sys.stderr)
        sys.exit(1)
    
    env = os.environ.copy()
    env["AIBIN_DISPATCHER"] = "1"
    
    result = subprocess.run(
        [sys.executable, str(impl_path)] + args[1:],
        env=env,
    )
    sys.exit(result.returncode)


if __name__ == "__main__":
    main()