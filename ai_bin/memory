#!/usr/bin/env -S uv run python
"""
DESCRIPTION: Dispatcher for memory operations. Delegates to implementation scripts.
Usage: uv run python ai_bin/memory <command> [args]
Commands:
  read            Read memory contents
  write <k> <v>   Write a key-value pair
  update <k> <v>  Update a key-value pair
  clear           Clear all memory
  -h, --help      Show this help

Note: This dispatcher prevents direct invocation of implementation scripts.
"""
from __future__ import annotations
import os
import sys
import subprocess
from pathlib import Path

BASE_DIR = Path(__file__).resolve().parent.parent
IMPL_DIR = Path(__file__).resolve().parent / "impl"

COMMANDS = {
    "read": IMPL_DIR / "memory-read",
    "write": IMPL_DIR / "memory-write",
    "update": IMPL_DIR / "memory-update",
    "clear": IMPL_DIR / "memory-clear",
}


def print_help() -> None:
    print(__doc__)


def main() -> None:
    args = sys.argv[1:]
    
    if not args or args[0] in ("-h", "--help"):
        print_help()
        sys.exit(0)
    
    command = args[0]
    
    if command not in COMMANDS:
        print(f"Error: Unknown command '{command}'", file=sys.stderr)
        print_help()
        sys.exit(1)
    
    impl_path = COMMANDS[command]
    if not impl_path.exists():
        print(f"Error: Implementation not found: {impl_path}", file=sys.stderr)
        sys.exit(1)
    
    env = os.environ.copy()
    env["AIBIN_DISPATCHER"] = "1"
    
    result = subprocess.run(
        [sys.executable, str(impl_path)] + args[1:],
        env=env,
    )
    sys.exit(result.returncode)


if __name__ == "__main__":
    main()